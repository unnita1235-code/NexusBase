# ─── LLM / Embedding ─────────────────────────────────────────
OPENAI_API_KEY=sk-...
EMBEDDING_MODEL=text-embedding-3-small
LLM_MODEL=gpt-4o-mini

# ─── Grader LLM (Gemini 3 Flash for CRAG) ───────────────────
GEMINI_API_KEY=AIza...
GRADER_MODEL=gemini-3.0-flash

# ─── Web Search Fallback ─────────────────────────────────────
TAVILY_API_KEY=tvly-...

# ─── Database ────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://nexus:nexus@localhost:5432/nexusbase

# ─── Knowledge Graph (Neo4j) ─────────────────────────────────
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=nexusbase
EXTRACTOR_MODEL=gemini-3.1-pro
GRAPH_TRAVERSAL_MAX_HOPS=3

# ─── RAG Tuning ──────────────────────────────────────────────
CHUNK_SIZE=512
CHUNK_OVERLAP=64
TOP_K=5
RRF_K=60

# ─── CRAG Scoring Weights ────────────────────────────────────
# Score(doc) = w1 * CosineSim(q, doc) + w2 * KeywordMatch(q, doc)
SCORE_W1=0.7
SCORE_W2=0.3
MAX_REWRITE_RETRIES=1

# ─── Server ──────────────────────────────────────────────────
BACKEND_PORT=8000
CORS_ORIGINS=http://localhost:3000
